{
  "name": "licer",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev:backend": "pnpm --filter @licer/backend dev",
    "dev:frontend": "pnpm --filter @licer/frontend dev",
    "build": "pnpm --filter @licer/backend build && pnpm --filter @licer/frontend build",
    "test": "pnpm --filter @licer/backend test",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown .",
    "ux:check": "node scripts/verify-ux.mjs"
  },
  "devDependencies": {
    "prettier": "3.5.3"
  }
}
