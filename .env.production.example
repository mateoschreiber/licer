NODE_ENV=production
PORT=3000
API_PREFIX=/api/v1
PUBLIC_URL=http://localhost:8088
FRONTEND_ORIGIN=http://localhost:8088
VITE_API_URL=/api/v1
FRONTEND_PORT=8088
POSTGRES_DB=licer
POSTGRES_USER=licer
POSTGRES_PASSWORD=change_on_server
DATABASE_URL=postgresql://licer:change_on_server@postgres:5432/licer?schema=public
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-random-secret-of-at-least-32-characters
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECURE=true
FILE_STORAGE_ROOT=/app/storage/private
MAX_UPLOAD_BYTES=2097152
AUTH_RATE_LIMIT_MAX_ATTEMPTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=600
AUTH_ACCOUNT_LOCK_SECONDS=900
PASSWORD_RESET_ENABLED=false
PASSWORD_RESET_TTL_MINUTES=30
# Configure SMTP y habilite PASSWORD_RESET_ENABLED=true para enviar enlaces reales.
# PASSWORD_RESET_BASE_URL=https://licitaciones.example.com/reset-password
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_FROM=no-reply@example.com
# SMTP_USER=
# SMTP_PASSWORD=
ADMIN_EMAIL=admin@localhost.test
ADMIN_PASSWORD=change_before_deploy
TEST_USER_EMAIL=prueba@local.test
TEST_USER_PASSWORD=change_before_deploy
TEST_SUPPLIER_RUC=80000000-0
