NODE_ENV=production
PORT=3000
API_PREFIX=/api/v1
PUBLIC_URL=http://localhost:8088
FRONTEND_ORIGIN=http://localhost:8088
VITE_API_URL=/api/v1
FRONTEND_PORT=8088
POSTGRES_DB=licer
POSTGRES_USER=licer
POSTGRES_PASSWORD=change_on_server
DATABASE_URL=postgresql://licer:change_on_server@postgres:5432/licer?schema=public
JWT_SECRET=generate_on_server
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=generate_on_server
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECURE=false
FILE_STORAGE_ROOT=/app/storage/private
MAX_UPLOAD_BYTES=2097152
ADMIN_EMAIL=admin@localhost.test
ADMIN_PASSWORD=change_before_deploy
TEST_USER_EMAIL=prueba@local.test
TEST_USER_PASSWORD=change_before_deploy
TEST_SUPPLIER_RUC=80000000-0
