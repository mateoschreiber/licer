NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/licer?schema=public
PORT=3000
API_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-random-secret-of-at-least-32-characters
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_SECURE=false
FILE_STORAGE_ROOT=./storage/private
MAX_UPLOAD_BYTES=2097152
AUTH_RATE_LIMIT_MAX_ATTEMPTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=600
AUTH_ACCOUNT_LOCK_SECONDS=900
PASSWORD_RESET_ENABLED=false
PASSWORD_RESET_TTL_MINUTES=30
# Para activar el restablecimiento por correo, configure estas variables:
# PASSWORD_RESET_BASE_URL=http://localhost:5173/reset-password
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_FROM=no-reply@example.com
# SMTP_USER=
# SMTP_PASSWORD=
ADMIN_EMAIL=admin@localhost.test
ADMIN_PASSWORD=ChangeMe123!
VITE_API_URL=http://localhost:3000/api/v1
